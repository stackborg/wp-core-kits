# Auto-detect text files and ensure LF line endings
* text=auto

# ── Export Ignore ─────────────────────────────────
# Files excluded when Composer downloads with --prefer-dist
# This is the standard way to keep dev files out of the distributed package

# Development & CI
/.github/           export-ignore
/.editorconfig      export-ignore
/.phpcs.xml         export-ignore
/phpstan.neon       export-ignore
/phpstan-bootstrap.php export-ignore
/phpunit.xml        export-ignore

# Tests
/tests/             export-ignore

# Documentation (dev-only)
/DEVELOPER_GUIDE.md export-ignore
/SECURITY.md        export-ignore
/CONTRIBUTING.md    export-ignore

# Distribution config (not needed in dist itself)
/.distignore        export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
