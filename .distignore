# Distribution ignore — files excluded from published package
# Used by deployment scripts and build tools
# Consumers install via Composer, so vendor/ is excluded

# ── Git / GitHub ──
.git/
.github/
.gitignore
.gitattributes
.distignore

# ── IDE ──
.vscode/
.idea/

# ── Dependencies (consumers install their own) ──
vendor/

# ── Tests ──
tests/
phpunit.xml
.phpunit.cache/
.phpunit.result.cache
coverage/

# ── Static analysis & linting ──
phpstan.neon
phpstan-bootstrap.php
.phpcs.xml

# ── Development configs ──
.editorconfig
.eslintrc*
.prettierrc*

# ── Documentation (dev only) ──
DEVELOPER_GUIDE.md
SECURITY.md

# ── Build artifacts & logs ──
composer.lock
*.log

# ── Environment ──
.env
.env.*
