.github/
.vscode/
.idea/
.phpunit.cache/
node_modules/

# Tests
tests/
phpunit.xml
phpstan.neon

# Development configs
.editorconfig
.eslintrc*
.prettierrc*

# Documentation (source only)
DEVELOPER_GUIDE.md
SECURITY.md

# Build artifacts
.phpunit.result.cache
composer.lock
*.log
