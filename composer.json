{
    "name": "stackborg/wp-core-kits",
    "description": "WordPress Plugin Foundation — abstraction layer for building scalable, maintainable WordPress plugins. Provides typed wrappers for WP APIs, DI container, REST infrastructure, and plugin architecture primitives.",
    "version": "1.0.1",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Stackborg",
            "email": "contact@stackborg.com",
            "homepage": "https://stackborg.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Stackborg\\WPCoreKits\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Stackborg\\WPCoreKits\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "analyse": "phpstan analyse --no-progress",
        "phpcs": "phpcs",
        "check": [
            "@phpcs",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
